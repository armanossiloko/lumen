# Editor configuration, see https://editorconfig.org
root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript files
[*.ts]
quote_type = single
indent_size = 2
ij_typescript_use_double_quotes = false

# Markdown files
[*.md]
max_line_length = off
trim_trailing_whitespace = false

# Xml files
[*.xml]
indent_size = 2
