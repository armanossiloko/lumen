# Copy to .env and adjust for docker compose up

# PostgreSQL
POSTGRES_USER=lumen
POSTGRES_PASSWORD=lumen
POSTGRES_DB=lumen

# Host ports
FRONTEND_PORT=8000
BACKEND_PORT=8002

# Public URL of the SPA (OAuth callback, external login redirects)
FRONTEND_URL=http://localhost:8000

# JWT signing key (min 32 characters for HMAC-SHA256)
JWT_KEY=lumen-docker-signing-key-change-me-32b
